# ──────────────────────────────────────────────────────
# SNS自動投稿システム 環境変数サンプル
# このファイルをコピーして .env を作成してください
# 本番では Secret Manager を使用するため、実際の値は不要です
# ──────────────────────────────────────────────────────

# GCP設定（必須）
GOOGLE_CLOUD_PROJECT=your-project-id
VERTEX_AI_REGION=us-east5        # Claude が使えるリージョン（us-east5 推奨）
VEO_REGION=us-central1           # Veo 2 が使えるリージョン
GCS_BUCKET=your-project-id-sns-videos

# WordPress設定（必須）
WORDPRESS_BASE_URL=https://your-wordpress-site.com
WORDPRESS_USERNAME=your-wp-username

# HubSpot SNS チャンネルID（HubSpot管理画面で確認）
HUBSPOT_FACEBOOK_CHANNEL_ID=your-facebook-channel-guid
HUBSPOT_INSTAGRAM_CHANNEL_ID=your-instagram-channel-guid

# LIFULL介護設定（APIが提供された場合のみ）
LIFULL_API_BASE_URL=https://api.kaigo.homes.co.jp/partner/v1

# ──────────────────────────────────────────────────────
# 以下は Secret Manager で管理するため .env には不要
# ローカル開発時のみ直接設定してください
# ──────────────────────────────────────────────────────
# WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx
# TIKTOK_ACCESS_TOKEN=xxxxxxxx
# LIFULL_LOGIN_EMAIL=you@example.com
# LIFULL_LOGIN_PASSWORD=your-password

# ──────────────────────────────────────────────────────
# 通知・セキュリティ設定（環境変数で直接設定）
# ──────────────────────────────────────────────────────
# WEBHOOK_SECRET=任意の長いランダム文字列（WP Webhooksの認証に使用）
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# SENDGRID_API_KEY=SG.xxxx
# NOTIFY_EMAIL_TO=yoriko.kikunaga@aozora-cg.com
# NOTIFY_EMAIL_FROM=noreply@your-domain.com
